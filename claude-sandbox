#!/usr/bin/env bash
set -euo pipefail

IDENTIFIER="${1:-}"
SESSION="claude-sandbox-${IDENTIFIER}"
IMAGE="claude-sandbox:latest"
MOUNT_DIR="$(pwd)"

if [ -z "$IDENTIFIER" ]; then
    tmux list-sessions -F "#{session_name}" 2>/dev/null \
        | grep "^claude-sandbox-" \
        | sed 's/^claude-sandbox-//'
    exit 0
fi

tmux_attach() {
    if [ -n "${TMUX:-}" ]; then
        exec tmux switch-client -t "$1"
    else
        exec tmux attach-session -t "$1"
    fi
}

if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux_attach "$SESSION"
fi

tmux set-option -gq extended-keys on 2>/dev/null || true

tmux new-session -d -s "$SESSION" \
    "podman run -it --rm \
        --userns=keep-id \
        --name claude-sandbox-${IDENTIFIER} \
        -v '${MOUNT_DIR}:/workspace:z' \
        -w /workspace \
        -v '${HOME}/.claude:/home/node/.claude:z' \
        -v '${HOME}/.claude.json:/home/node/.claude.json:z' \
        -e ANTHROPIC_API_KEY \
        ${IMAGE}"

tmux_attach "$SESSION"
